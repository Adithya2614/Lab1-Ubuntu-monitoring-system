# =============================================================
# WMI — Ubuntu Lab Monitoring System
# Environment Variables Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# --- Database ---
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://wmi_user:changeme@localhost:5432/wmi_db

# --- Ansible ---
# Path to the ansible directory (relative to project root)
ANSIBLE_DIR=./ansible

# Ansible Vault password for encrypting/decrypting secrets
ANSIBLE_VAULT_PASSWORD=changeme

# --- WebSocket ---
# Interval in seconds for periodic metric pushes
WS_PUSH_INTERVAL=5

# --- Logging ---
# Directory for log files (relative to project root)
LOG_DIR=./logs

# --- Security ---
# Secret key for signing tokens / sessions (generate a random one)
SECRET_KEY=generate-a-random-key-here

# --- Server ---
# Backend host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
